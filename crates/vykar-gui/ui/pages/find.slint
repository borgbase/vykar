import { VerticalBox, HorizontalBox, Button, LineEdit, StandardTableView } from "std-widgets.slint";

export component FindPage inherits Rectangle {
    in property <string> repo_name;
    in property <bool> operation_busy;
    in-out property <string> name_pattern;
    in property <string> status_text;
    in property <[[StandardListViewItem]]> result_rows;

    callback search_clicked();

    VerticalBox {
        padding: 12px;
        spacing: 8px;

        HorizontalBox {
            padding: 0px;
            spacing: 8px;
            Text {
                text: root.repo_name != "" ? "Find Files: " + root.repo_name : "Find Files";
                vertical-alignment: center;
                font-weight: 700;
                font-size: 16px;
                horizontal-stretch: 1;
            }
        }

        HorizontalBox {
            padding: 0px;
            spacing: 8px;
            Text {
                text: "Name pattern:";
                vertical-alignment: center;
            }
            LineEdit {
                horizontal-stretch: 1;
                text <=> root.name_pattern;
                placeholder-text: "e.g. *.rs, config*";
                accepted => {
                    if (!root.operation_busy) {
                        root.search_clicked();
                    }
                }
            }
            Button {
                text: "Search";
                primary: true;
                enabled: !root.operation_busy;
                clicked => { root.search_clicked(); }
            }
        }

        StandardTableView {
            vertical-stretch: 1;
            columns: [
                { title: "Snapshot", width: 160px },
                { title: "Path", horizontal-stretch: 1 },
                { title: "Date", width: 150px },
                { title: "Size", width: 90px },
                { title: "Status", width: 90px },
            ];
            rows: root.result_rows;
        }

        HorizontalBox {
            padding: 0px;
            spacing: 8px;
            Text {
                vertical-alignment: center;
                text: root.status_text;
                color: #666666;
                horizontal-stretch: 1;
            }
        }
    }
}
