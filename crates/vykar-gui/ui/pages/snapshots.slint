import { VerticalBox, HorizontalBox, Button, StandardTableView, Palette } from "std-widgets.slint";

export component SnapshotsPage inherits Rectangle {
    in property <string> repo_name;
    in property <[[StandardListViewItem]]> snapshot_rows;
    in property <int> selected_count;
    in property <bool> operation_busy;
    in property <bool> is_mount_active;

    callback refresh_clicked();
    callback prune_clicked();
    callback restore_selected();
    callback delete_selected();
    callback mount_selected();
    callback row_clicked(/* row */ int, /* toggle */ bool, /* range */ bool);
    callback sort_ascending(int);
    callback sort_descending(int);

    VerticalBox {
        padding: 12px;
        spacing: 8px;

        HorizontalBox {
            padding: 0px;
            spacing: 8px;
            Text {
                text: root.repo_name != "" ? "Snapshots: " + root.repo_name : "Snapshots";
                vertical-alignment: center;
                font-weight: 700;
                font-size: 16px;
                horizontal-stretch: 1;
            }
            Button {
                text: "Refresh";
                enabled: !root.operation_busy;
                clicked => { root.refresh_clicked(); }
            }
            Button {
                text: "Prune";
                primary: true;
                enabled: !root.operation_busy;
                clicked => { root.prune_clicked(); }
            }
        }

        snapshot-table := StandardTableView {
            vertical-stretch: 1;
            columns: [
                { title: "ID" },
                { title: "Host" },
                { title: "Time" },
                { title: "Label" },
                { title: "Files" },
                { title: "Size" },
            ];
            rows: root.snapshot_rows;
            sort-ascending(col-idx) => { root.sort_ascending(col-idx); }
            sort-descending(col-idx) => { root.sort_descending(col-idx); }
            row-pointer-event(idx, ev, pos) => {
                if (ev.kind == PointerEventKind.down && ev.button == PointerEventButton.left) {
                    root.row_clicked(idx,
                        ev.modifiers.control || ev.modifiers.meta,
                        ev.modifiers.shift);
                }
            }
            // Suppress the widget's native single-row highlight: it conflicts
            // with our own "● " prefix marker. The widget calls set-current-row
            // on click which writes current-row and fires this callback; a
            // direct assignment back to -1 bypasses set-current-row so it
            // doesn't recurse.
            current-row-changed(r) => {
                if (r != -1) {
                    snapshot-table.current-row = -1;
                }
            }
        }

        if root.selected_count > 0: Text {
            text: root.selected_count + " selected";
            color: Palette.foreground;
            font-size: 12px;
        }

        HorizontalBox {
            padding: 0px;
            spacing: 8px;
            Button {
                text: "Restore Selected Snapshot";
                enabled: !root.operation_busy && root.selected_count == 1;
                clicked => { root.restore_selected(); }
            }
            Button {
                text: root.selected_count > 0
                    ? "Delete " + root.selected_count + " Selected"
                    : "Delete Selected";
                enabled: !root.operation_busy && root.selected_count > 0;
                clicked => { root.delete_selected(); }
            }
            Button {
                text: "Mount Selected";
                enabled: !root.operation_busy && !root.is_mount_active && root.selected_count == 1;
                clicked => { root.mount_selected(); }
            }
        }
    }
}
