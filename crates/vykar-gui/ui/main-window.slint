import { VerticalBox, HorizontalBox, Button, ScrollView, Palette, StandardButton } from "std-widgets.slint";
import { RepoInfo, SourceInfo, Page, FindSnapshotGroup } from "components/types.slint";
import { SideBarSection, SideBarItem, SideBarSubItem, SideBarActionRow } from "components/side_bar.slint";
import { OverviewPage } from "pages/overview.slint";
import { SnapshotsPage } from "pages/snapshots.slint";
import { FindPage } from "pages/find.slint";
import { SourcesPage } from "pages/sources.slint";
import { AdvancedPage } from "pages/advanced.slint";
import { LogPage } from "pages/log.slint";
import { SettingsPage } from "pages/settings.slint";

export { RepoInfo, SourceInfo, Page, FindSnapshotGroup }

export component MainWindow inherits Window {
    in-out property <string> config_path;
    in-out property <string> schedule_brief;
    in-out property <string> status_text;
    in-out property <string> version_text;
    in-out property <[[StandardListViewItem]]> log_rows: [];

    // Operation busy state — disables all action buttons
    in-out property <bool> operation_busy: false;

    // Repo model — drives the sidebar REPOSITORIES section and overview
    in-out property <bool> repo_loading: true;
    in-out property <[RepoInfo]> repo_model: [];

    // Source model
    in-out property <[SourceInfo]> source_model: [];
    // Per-repo filtered source model for the Overview page
    in-out property <[SourceInfo]> repo_source_model: [];

    // Snapshot table
    in-out property <[[StandardListViewItem]]> snapshot_rows: [];
    // Number of rows currently selected in the Snapshots table (drives bulk button labels).
    in-out property <int> snapshot_selected_count: 0;
    // Latest 3 snapshots (4 cols: ID / Time / Files / Size) for the Overview page
    in-out property <[[StandardListViewItem]]> recent_snapshot_rows: [];

    // Find state (embedded page)
    in-out property <string> find_name_pattern;
    in-out property <string> find_status_text: "Enter a name pattern and click Search.";
    in-out property <[FindSnapshotGroup]> find_groups: [];
    in-out property <bool> find_has_searched: false;

    // Editor state (Advanced page)
    in-out property <string> editor_text: "";
    in-out property <string> editor_baseline: "";
    in-out property <string> editor_status: "";
    in-out property <bool> editor_dirty: false;
    in-out property <string> editor_font_family: "";

    // Navigation state — see `components/types.slint::Page` for the enum.
    in-out property <Page> current_page: Page.overview;
    in-out property <int> current_repo_index: 0;

    // Pages scoped to a repository (sidebar sub-items appear only for these).
    property <bool> repo_scoped_page:
        root.current_page == Page.overview
        || root.current_page == Page.snapshots
        || root.current_page == Page.find;

    // Mount state (WebDAV server)
    in-out property <bool> is_mount_active: false;
    in-out property <string> mount_url: "";

    // Settings tab state
    in-out property <bool> start_at_login: false;
    in-out property <bool> start_in_background: false;
    in-out property <bool> start_in_background_enabled: true;

    callback open_config_clicked();
    callback switch_config_clicked();
    callback save_and_apply_clicked();
    callback discard_clicked();
    callback reload_config_clicked();
    callback clear_locks_clicked();
    callback clear_sessions_clicked();
    callback backup_repo_clicked(/* index */ int);
    callback backup_source_clicked(/* index */ int);
    callback toggle_source_expanded(/* index */ int);
    callback backup_repo_source_clicked(/* index */ int);
    callback toggle_repo_source_expanded(/* index */ int);
    callback refresh_snapshots_clicked();
    callback prune_snapshots_clicked();
    callback restore_selected_snapshot_clicked();
    callback diff_selected_snapshots_clicked();
    callback delete_selected_snapshots_clicked();
    callback mount_selected_snapshot_clicked();
    callback snapshot_row_clicked(/* row */ int, /* toggle */ bool, /* range */ bool);
    callback stop_mount_clicked();
    callback open_mount_url_clicked();
    callback snapshot_sort_ascending(/* column */ int);
    callback snapshot_sort_descending(/* column */ int);
    callback find_search_clicked();
    callback select_page(Page);
    callback select_repo_and_page(/* repo_index */ int, Page);
    callback cancel_operation_clicked();
    callback close_window();
    callback start_at_login_toggled(/* checked */ bool);
    callback start_in_background_toggled(/* checked */ bool);
    callback release-focus();

    // Derived: the currently selected RepoInfo (or an empty fallback).
    property <RepoInfo> active_repo: root.current_repo_index >= 0
        && root.current_repo_index < root.repo_model.length
        ? root.repo_model[root.current_repo_index]
        : { name: "", url: "", snapshots: "", last_snapshot: "", size: "" };

    property <string> active_repo_title_suffix:
        root.active_repo.name != "" ? " - " + root.active_repo.name : "";

    property <string> window_title:
        root.current_page == Page.overview ? "Overview" + root.active_repo_title_suffix + " - Vykar Backup"
        : root.current_page == Page.snapshots ? "Snapshots" + root.active_repo_title_suffix + " - Vykar Backup"
        : root.current_page == Page.find ? "Find Files" + root.active_repo_title_suffix + " - Vykar Backup"
        : root.current_page == Page.sources ? "Sources - Vykar Backup"
        : root.current_page == Page.advanced ? "Advanced Config - Vykar Backup"
        : root.current_page == Page.log ? "Activity Log - Vykar Backup"
        : "Settings - Vykar Backup";

    release-focus => { focus-sink.focus(); }
    title: root.window_title;
    preferred-width: 1100px;
    preferred-height: 760px;

    focus-sink := FocusScope {
        key-pressed(event) => {
            if ((event.modifiers.meta || event.modifiers.control) && event.text == "w") {
                root.close_window();
                return accept;
            }
            return reject;
        }

    VerticalBox {
        padding: 0px;
        spacing: 0px;

        // ── Sidebar + page switcher ──
        HorizontalLayout {
            vertical-stretch: 1;
            spacing: 0px;

            // Sidebar
            Rectangle {
                width: 220px;
                background: Palette.background.darker(0.04);

                VerticalLayout {
                    padding: 10px;
                    spacing: 10px;

                    ScrollView {
                        vertical-stretch: 1;
                        VerticalLayout {
                            spacing: 10px;
                            alignment: start;

                            // REPOSITORIES
                            SideBarSection {
                                title: "REPOSITORIES";
                                if root.repo_loading: Text {
                                    text: "Loading...";
                                    color: #888888;
                                    font-size: 11px;
                                }
                                for repo[idx] in root.repo_model: VerticalLayout {
                                    spacing: 0px;
                                    SideBarItem {
                                        text: repo.name;
                                        clicked => {
                                            root.select_repo_and_page(idx,
                                                root.repo_scoped_page ? root.current_page : Page.overview);
                                        }
                                    }
                                    // Nested sub-items only under the selected repo, on a repo-scoped page
                                    if root.current_repo_index == idx && root.repo_scoped_page: VerticalLayout {
                                        spacing: 0px;
                                        SideBarSubItem {
                                            text: "Overview";
                                            glyph: ">";
                                            selected: root.current_page == Page.overview;
                                            clicked => { root.select_repo_and_page(idx, Page.overview); }
                                        }
                                        SideBarSubItem {
                                            text: "Snapshots";
                                            glyph: ">";
                                            selected: root.current_page == Page.snapshots;
                                            clicked => { root.select_repo_and_page(idx, Page.snapshots); }
                                        }
                                        SideBarSubItem {
                                            text: "Find Files";
                                            glyph: ">";
                                            selected: root.current_page == Page.find;
                                            clicked => { root.select_repo_and_page(idx, Page.find); }
                                        }
                                    }
                                }
                            }

                            // CONFIG
                            SideBarSection {
                                title: "CONFIG";
                                SideBarItem {
                                    text: "Sources";
                                    count: root.source_model.length;
                                    selected: root.current_page == Page.sources;
                                    clicked => { root.select_page(Page.sources); }
                                }
                                SideBarItem {
                                    text: "Advanced";
                                    selected: root.current_page == Page.advanced;
                                    clicked => { root.select_page(Page.advanced); }
                                }
                            }

                            // Standalone
                            VerticalLayout {
                                spacing: 2px;
                                SideBarItem {
                                    text: "Log";
                                    selected: root.current_page == Page.log;
                                    clicked => { root.select_page(Page.log); }
                                }
                                SideBarItem {
                                    text: "Settings";
                                    selected: root.current_page == Page.settings;
                                    clicked => { root.select_page(Page.settings); }
                                }
                            }
                        }
                    }
                }
            }

            Rectangle { width: 1px; background: #d5d5d5; }

            // Page area
            Rectangle {
                horizontal-stretch: 1;

                if root.current_page == Page.overview: OverviewPage {
                    repo: root.active_repo;
                    schedule_brief: root.schedule_brief;
                    source_model: root.repo_source_model;
                    snapshot_rows: root.recent_snapshot_rows;
                    operation_busy: root.operation_busy;
                    backup_clicked => { root.backup_repo_clicked(root.current_repo_index); }
                    view_all_snapshots_clicked => {
                        root.select_repo_and_page(root.current_repo_index, Page.snapshots);
                    }
                    view_all_sources_clicked => { root.select_page(Page.sources); }
                    toggle_source_expanded(i) => { root.toggle_repo_source_expanded(i); }
                    backup_source(i) => { root.backup_repo_source_clicked(i); }
                }

                if root.current_page == Page.snapshots: SnapshotsPage {
                    repo_name: root.active_repo.name;
                    snapshot_rows: root.snapshot_rows;
                    selected_count: root.snapshot_selected_count;
                    operation_busy: root.operation_busy;
                    is_mount_active: root.is_mount_active;
                    refresh_clicked => { root.refresh_snapshots_clicked(); }
                    prune_clicked => { root.prune_snapshots_clicked(); }
                    restore_selected => { root.restore_selected_snapshot_clicked(); }
                    diff_selected => { root.diff_selected_snapshots_clicked(); }
                    delete_selected => { root.delete_selected_snapshots_clicked(); }
                    mount_selected => { root.mount_selected_snapshot_clicked(); }
                    row_clicked(r, t, s) => { root.snapshot_row_clicked(r, t, s); }
                    sort_ascending(c) => { root.snapshot_sort_ascending(c); }
                    sort_descending(c) => { root.snapshot_sort_descending(c); }
                }

                if root.current_page == Page.find: FindPage {
                    repo_name: root.active_repo.name;
                    operation_busy: root.operation_busy;
                    name_pattern <=> root.find_name_pattern;
                    status_text: root.find_status_text;
                    groups: root.find_groups;
                    has_searched: root.find_has_searched;
                    search_clicked => { root.find_search_clicked(); }
                }

                if root.current_page == Page.sources: SourcesPage {
                    source_model: root.source_model;
                    operation_busy: root.operation_busy;
                    backup_source(i) => { root.backup_source_clicked(i); }
                    toggle_source_expanded(i) => { root.toggle_source_expanded(i); }
                    edit_config_clicked => { root.select_page(Page.advanced); }
                }

                if root.current_page == Page.advanced: AdvancedPage {
                    config_path: root.config_path;
                    editor_text <=> root.editor_text;
                    editor_baseline: root.editor_baseline;
                    editor_status: root.editor_status;
                    editor_dirty <=> root.editor_dirty;
                    editor_font_family: root.editor_font_family;
                    operation_busy: root.operation_busy;
                    selected_repo_name: root.active_repo.name;
                    open_config_clicked => { root.open_config_clicked(); }
                    switch_config_clicked => { root.switch_config_clicked(); }
                    reload_config_clicked => { root.reload_config_clicked(); }
                    save_clicked => { root.save_and_apply_clicked(); }
                    discard_clicked => { root.discard_clicked(); }
                    clear_locks_clicked => { root.clear_locks_clicked(); }
                    clear_sessions_clicked => { root.clear_sessions_clicked(); }
                    text_edited(new_text) => {
                        root.editor_dirty = (new_text != root.editor_baseline);
                        root.editor_status = "";
                    }
                }

                if root.current_page == Page.log: LogPage {
                    log_rows: root.log_rows;
                }

                if root.current_page == Page.settings: SettingsPage {
                    start_at_login <=> root.start_at_login;
                    start_in_background <=> root.start_in_background;
                    start_in_background_enabled: root.start_in_background_enabled;
                    start_at_login_toggled(c) => { root.start_at_login_toggled(c); }
                    start_in_background_toggled(c) => { root.start_in_background_toggled(c); }
                }
            }
        }

        // ── Footer ──
        Rectangle { height: 1px; background: #d5d5d5; }

        if root.is_mount_active: Rectangle {
            property <bool> dark: Palette.color-scheme == ColorScheme.dark;
            background: dark ? #1f3a5f : #e8f4fd;
            HorizontalBox {
                padding-left: 12px;
                padding-right: 12px;
                padding-top: 6px;
                padding-bottom: 6px;
                spacing: 8px;
                HorizontalLayout {
                    horizontal-stretch: 1;
                    spacing: 4px;
                    if root.mount_url == "": Text {
                        text: "Loading...";
                        vertical-alignment: center;
                        color: Palette.foreground;
                    }
                    if root.mount_url != "": Text {
                        text: "Serving at";
                        vertical-alignment: center;
                        color: Palette.foreground;
                    }
                    if root.mount_url != "": TouchArea {
                        mouse-cursor: pointer;
                        clicked => { root.open_mount_url_clicked(); }
                        horizontal-stretch: 1;
                        HorizontalLayout {
                            alignment: start;
                            Text {
                                text: root.mount_url;
                                color: dark ? #6cb6ff : #0066cc;
                                vertical-alignment: center;
                            }
                        }
                    }
                }
                Button {
                    text: "Stop Mount";
                    clicked => { root.stop_mount_clicked(); }
                }
            }
        }

        HorizontalBox {
            padding-left: 12px;
            padding-right: 12px;
            padding-top: 6px;
            padding-bottom: 6px;
            spacing: 8px;

            Text { text: "Status:"; vertical-alignment: center; }
            Text { text: root.status_text; vertical-alignment: center; horizontal-stretch: 1; }
            if root.operation_busy: Button {
                text: "Cancel";
                clicked => { root.cancel_operation_clicked(); }
            }
            Text { text: root.version_text; vertical-alignment: center; color: #888888; }
        }
    }
    }
}
