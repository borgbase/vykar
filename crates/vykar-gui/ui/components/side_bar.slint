        }
    ]

    state := Rectangle {
        opacity: 0;
        background: #4a90d9;
        border-radius: 4px;
        animate opacity { duration: 120ms; }
    }

    HorizontalLayout {
        padding-left: 10px;
        padding-right: 10px;

        Text {
            text: root.text;
            vertical-alignment: center;
            color: #4a90d9;
            font-size: 12px;
        }
    }

    touch := TouchArea {
        width: 100%;
        height: 100%;
        mouse-cursor: pointer;
    }
}
