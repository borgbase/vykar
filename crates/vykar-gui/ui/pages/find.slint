import { VerticalBox, HorizontalBox, Button, LineEdit, ScrollView, StandardTableView } from "std-widgets.slint";
import { FindSnapshotGroup } from "../components/types.slint";

export component FindPage inherits Rectangle {
    in property <string> repo_name;
    in property <bool> operation_busy;
    in-out property <string> name_pattern;
    in property <string> status_text;
    in property <[FindSnapshotGroup]> groups;
    in property <bool> has_searched;

    callback search_clicked();

    VerticalBox {
        padding: 12px;
        spacing: 8px;

        HorizontalBox {
            padding: 0px;
            spacing: 8px;
            Text {
                text: root.repo_name != "" ? "Find Files: " + root.repo_name : "Find Files";
                vertical-alignment: center;
                font-weight: 700;
                font-size: 16px;
                horizontal-stretch: 1;
            }
        }

        HorizontalBox {
            padding: 0px;
            spacing: 8px;
            Text {
                text: "Name pattern:";
                vertical-alignment: center;
            }
            LineEdit {
                horizontal-stretch: 1;
                text <=> root.name_pattern;
                placeholder-text: "e.g. *.rs, config*";
                accepted => {
                    if (!root.operation_busy) {
                        root.search_clicked();
                    }
                }
            }
            Button {
                text: "Search";
                primary: true;
                enabled: !root.operation_busy;
                clicked => { root.search_clicked(); }
            }
        }

        ScrollView {
            vertical-stretch: 1;
            VerticalLayout {
                alignment: start;
                spacing: 12px;
                if root.groups.length == 0 && root.has_searched && !root.operation_busy: Text {
                    text: "No results.";
                    color: #888888;
                }
                for group in root.groups: VerticalLayout {
                    alignment: start;
                    spacing: 4px;
                    HorizontalLayout {
                        spacing: 8px;
                        Text {
                            text: "Snapshot " + group.snapshot_id + " — " + group.snapshot_time;
                            font-weight: 700;
                            horizontal-stretch: 1;
                        }
                        Text {
                            text: group.row_count + " match" + (group.row_count == 1 ? "" : "es");
                            color: #888888;
                            vertical-alignment: center;
                        }
                    }
                    StandardTableView {
                        height: (group.row_count + 1) * 28px + 6px;
                        columns: [
                            { title: "Path", horizontal-stretch: 1 },
                            { title: "Modified", width: 150px },
                            { title: "Size", width: 90px },
                            { title: "Status", width: 100px },
                        ];
                        rows: group.rows;
                    }
                }
            }
        }

        HorizontalBox {
            padding: 0px;
            spacing: 8px;
            Text {
                vertical-alignment: center;
                text: root.status_text;
                color: #666666;
                horizontal-stretch: 1;
            }
        }
    }
}
