import { VerticalBox, HorizontalBox, Button, LineEdit } from "std-widgets.slint";

export component PasswordDialog inherits Window {
    in property <string> dialog-title: "Vykar Backup";
    in property <string> dialog-message: "";
    // Non-empty when re-prompting after an incorrect passphrase.
    in property <string> error-text: "";
    // Toggled by the Show/Hide button to reveal the typed passphrase.
    property <bool> password-visible: false;

    callback submitted(string);
    callback cancelled();

    title: root.dialog-title;
    preferred-width: 450px;
    preferred-height: 130px;

    VerticalBox {
        padding: 16px;
        spacing: 12px;

        Text { text: root.dialog-message; wrap: word-wrap; }

        if root.error-text != "": Text {
            text: root.error-text;
            color: #d32f2f;
            font-size: 12px;
            wrap: word-wrap;
        }

        HorizontalBox {
            padding: 0px;
            spacing: 6px;
            input := LineEdit {
                horizontal-stretch: 1;
                input-type: root.password-visible ? InputType.text : InputType.password;
                placeholder-text: "Passphrase";
                accepted => { root.submitted(self.text); }
            }
            Button {
                text: root.password-visible ? "Hide" : "Show";
                clicked => { root.password-visible = !root.password-visible; }
            }
        }

        HorizontalBox {
            alignment: end;
            spacing: 8px;
            Button { text: "Cancel"; clicked => { root.cancelled(); } }
            Button { text: "OK"; clicked => { root.submitted(input.text); } }
        }
    }
}
