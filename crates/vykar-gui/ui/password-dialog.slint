import { VerticalBox, HorizontalBox, Button, LineEdit } from "std-widgets.slint";

export component PasswordDialog inherits Window {
    in property <string> dialog-title: "Vykar Backup";
    in property <string> dialog-message: "";

    callback submitted(string);
    callback cancelled();

    title: root.dialog-title;
    preferred-width: 450px;
    preferred-height: 130px;

    VerticalBox {
        padding: 16px;
        spacing: 12px;

        Text { text: root.dialog-message; wrap: word-wrap; }

        input := LineEdit {
            input-type: password;
            placeholder-text: "Passphrase";
            accepted => { root.submitted(self.text); }
        }

        HorizontalBox {
            alignment: end;
            spacing: 8px;
            Button { text: "Cancel"; clicked => { root.cancelled(); } }
            Button { text: "OK"; clicked => { root.submitted(input.text); } }
        }
    }
}
